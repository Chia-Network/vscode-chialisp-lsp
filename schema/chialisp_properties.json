{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "definitions": {
        "configurations": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["name", "program"],
                "properties": {
                    "name": {
                        "description": "Name of the configuration",
                        "type": "string"
                    },
                    "args": {
                        "description": "Arguments to specify the environment for running the program",
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "default": ["()"]
                    },
                    "symbols": {
                        "description": "Symbol file to use for launching pre-compiled clvm or classic chialisp",
                        "type": "string",
                        "default": ""
                    },
                    "program": {
                        "description": "Program to run (hex, clvm or clsp)",
                        "type": "string"
                    },
                    "run_args": {
                        "description": "CLVM data to use as the argument environment for ARM GDB debug runs",
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "default": ["()"]
                    }
                }
            }
        }
    }
}
