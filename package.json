{
    "name": "chialisp",
    "displayName": "Chialisp",
    "icon": "images/chialisp.png",
    "description": "A Rust LSP client for Chialisp",
    "publisher": "ChiaNetwork",
    "version": "1.2.5",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "repository": "https://github.com/Chia-Network/vscode-chialisp-lsp",
    "activationEvents": [
        "onLanguage:chialisp",
        "onCommand:chialisp.startDebug",
        "onCommand:chialisp.gdbDebug",
        "onDebug",
        "onDebugResolve:chialisp",
        "workspaceContains:chialisp.json",
        "onFileSystem:cpptools-schema"
    ],
    "contributes": {
        "languages": [
            {
                "id": "chialisp",
                "aliases": [
                    "Chialisp",
                    "chialisp"
                ],
                "extensions": [
                    ".cl",
                    ".clvm",
                    ".clsp",
                    ".clib",
                    ".clinc"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "dark": "images/chialisp_dark.svg",
                    "light": "images/chialisp_light.svg"
                }
            }
        ],
        "grammars": [
            {
                "language": "chialisp",
                "scopeName": "source.chialisp",
                "path": "./syntaxes/chialisp.tmGrammar.json"
            }
        ],
        "configuration": [
            {
                "type": "object",
                "title": "Chialisp",
                "properties": {
                    "chialisp.stderrLogPath": {
                        "type": "string",
                        "default": "",
                        "description": "filename for stderr log for lsp"
                    },
                    "chialisp.gdb.backend": {
                        "type": "string",
                        "enum": ["auto", "local", "web"],
                        "default": "auto",
                        "description": "Select local gdb-multiarch, web-gdb-node, or auto detection."
                    },
                    "chialisp.gdb.localDebuggerPath": {
                        "type": "string",
                        "default": "gdb-multiarch",
                        "description": "Path or command name for local gdb executable."
                    },
                    "chialisp.gdb.serverAddress": {
                        "type": "string",
                        "default": "localhost:9001",
                        "description": "Host:port where the wasm gdb stub listens."
                    },
                    "chialisp.gdb.prettyPrinterPath": {
                        "type": "string",
                        "default": "${workspaceFolder}/support/gdb_print_sexp.py",
                        "description": "Path to python pretty-printer script sourced by gdb."
                    },
                    "chialisp.gdb.webNodePath": {
                        "type": "string",
                        "default": "node",
                        "description": "Node executable used to start web-gdb-node."
                    },
                    "chialisp.gdb.wasmRunnerNodePath": {
                        "type": "string",
                        "default": "node",
                        "description": "Node executable used to start the local wasm gdb runner."
                    },
                    "chialisp.gdb.wasmRunnerPath": {
                        "type": "string",
                        "default": "",
                        "description": "Override path to the local wasm gdb runner script. Empty means use extension-bundled debug/build/gdb_runner.js."
                    },
                    "chialisp.gdb.defaultEnv": {
                        "type": "string",
                        "default": "()",
                        "description": "Default Chialisp environment expression passed to compile_to_arm_elf."
                    },
                    "chialisp.gdb.webGdbRunnerPath": {
                        "type": "string",
                        "default": "${workspaceFolder}/node_modules/web-gdb-node/src/runner.js",
                        "description": "Path to web-gdb-node runner.js."
                    },
                    "chialisp.gdb.webGdbExtraArgs": {
                        "type": "array",
                        "description": "Additional arguments passed to web-gdb-node.",
                        "items": {
                            "type": "string"
                        },
                        "default": []
                    }
                }
            }
        ],
        "commands": [
            {
                "command": "chialisp.locateIncludePath",
                "title": "Locate include file",
                "category": "Chialisp"
            },
            {
                "command": "chialisp.startDebug",
                "title": "Start Chialisp Debug"
            },
            {
                "command": "chialisp.gdbDebug",
                "title": "Chialisp: GDB Debug",
                "category": "Chialisp"
            }
        ],
        "menus": {
            "explorer/context": [
                {
                    "when": "resourceFilename =~ /\\.clsp$/ || resourceFilename =~ /\\.clvm$/",
                    "command": "chialisp.startDebug"
                },
                {
                    "when": "resourceFilename =~ /\\.clsp$/ || resourceFilename =~ /\\.clvm$/",
                    "command": "chialisp.gdbDebug"
                }
            ]
        },
        "breakpoints": [
            {
                "language": "Chialisp"
            },
            {
                "language": "chialisp"
            }
        ],
        "debuggers": [
            {
                "type": "chialisp",
                "label": "chialisp debugger",
                "languages": [
                    "Chialisp",
                    "chialisp"
                ],
                "jsonValidation": [
                    {
                        "fileMatch": "schema/chialisp_properties.json",
                        "url": "chialisp-schema:///schema/chialisp_properties.json"
                    }
                ],
                "configurationAttributes": {
                    "launch": {
                        "required": [
                            "program",
                            "args",
                            "type"
                        ],
                        "properties": {
                            "program": {
                                "type": "string",
                                "description": "The chialisp program to run."
                            },
                            "args": {
                                "type": "array",
                                "description": "Environment for program.  Specified as an array of strings for compatibility with other debug style tools.",
                                "items": {
                                    "type": "string"
                                },
                                "default": [
                                    "()"
                                ]
                            },
                            "symbols": {
                                "type": "string",
                                "description": "Symbol file to use.  Can specify additional information for classic chialisp and inputs files.",
                                "default": ""
                            }
                        }
                    }
                }
            }
        ]
    },
    "keywords": [
        "chia",
        "lisp",
        "chialisp",
        "vscode",
        "extension"
    ],
    "bugs": {
        "url": "https://github.com/Chia-Network/vscode-chialisp-lsp/issues"
    },
    "homepage": "https://chialisp.com",
    "license": "Apache 2.0",
    "main": "./out/extension.js",
    "scripts": {
        "vscode:prepublish": "make && npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint",
        "test": "node ./out/test/runTest.js"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@stylistic/eslint-plugin": "^5.9.0",
        "@types/glob": "^9.0.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "25.6.0",
        "@types/vscode": "^1.85.0",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "3.7.1",
        "eslint": "^10.0.3",
        "glob": "^13.0.3",
        "mocha": "^11.7.5",
        "typescript": "^5.9.3",
        "webpack": "^5.106.2",
        "webpack-cli": "^7.0.2"
    }
}
